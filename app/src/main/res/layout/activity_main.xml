<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/main_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:layout_marginTop="12dp"
        android:text="TG Proxy"
        android:textColor="#3390EC"
        android:textSize="24sp"
        android:textStyle="bold" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:layout_marginTop="8dp"
        android:layout_marginStart="12dp"
        android:layout_marginEnd="12dp"
        android:background="@drawable/card_bg"
        android:gravity="center"
        android:orientation="horizontal">

        <LinearLayout
            android:id="@+id/tab_proxy"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center"
            android:clickable="true"
            android:focusable="true"
            android:foreground="?android:attr/selectableItemBackground">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="⚡ Прокси"
                android:textColor="#E0E0E0"
                android:textSize="12sp"
                android:textStyle="bold" />
        </LinearLayout>

        <View
            android:layout_width="1dp"
            android:layout_height="24dp"
            android:background="#333333" />

        <LinearLayout
            android:id="@+id/tab_warp"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center"
            android:clickable="true"
            android:focusable="true"
            android:foreground="?android:attr/selectableItemBackground">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🔑 WARP"
                android:textColor="#E0E0E0"
                android:textSize="12sp"
                android:textStyle="bold" />
        </LinearLayout>

        <View
            android:layout_width="1dp"
            android:layout_height="24dp"
            android:background="#333333" />

        <LinearLayout
            android:id="@+id/tab_proxy_list"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center"
            android:clickable="true"
            android:focusable="true"
            android:foreground="?android:attr/selectableItemBackground">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="📋 Список"
                android:textColor="#E0E0E0"
                android:textSize="12sp"
                android:textStyle="bold" />
        </LinearLayout>

        <View
            android:layout_width="1dp"
            android:layout_height="24dp"
            android:background="#333333" />

        <LinearLayout
            android:id="@+id/tab_dns"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center"
            android:clickable="true"
            android:focusable="true"
            android:foreground="?android:attr/selectableItemBackground">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🌐 DNS"
                android:textColor="#E0E0E0"
                android:textSize="12sp"
                android:textStyle="bold" />
        </LinearLayout>

    </LinearLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fillViewport="true">

        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <!-- ======== TAB: PROXY ======== -->
            <LinearLayout
                android:id="@+id/content_proxy"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp"
                android:visibility="visible">

                <TextView
                    android:id="@+id/tv_status"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:layout_marginTop="4dp"
                    android:text="❌ Остановлен"
                    android:textColor="#F44336"
                    android:textSize="18sp"
                    android:textStyle="bold" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:gravity="center"
                    android:orientation="horizontal">

                    <Button
                        android:id="@+id/btn_start"
                        android:layout_width="0dp"
                        android:layout_height="48dp"
                        android:layout_marginEnd="6dp"
                        android:layout_weight="1"
                        android:background="@drawable/btn_start_bg"
                        android:text="Запустить"
                        android:textAllCaps="false"
                        android:textColor="#FFFFFF"
                        android:textSize="15sp"
                        android:textStyle="bold" />

                    <Button
                        android:id="@+id/btn_stop"
                        android:layout_width="0dp"
                        android:layout_height="48dp"
                        android:layout_marginStart="6dp"
                        android:layout_weight="1"
                        android:background="@drawable/btn_stop_bg"
                        android:enabled="false"
                        android:text="Остановить"
                        android:textAllCaps="false"
                        android:textColor="#FFFFFF"
                        android:textSize="15sp"
                        android:textStyle="bold" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="14dp"
                    android:background="@drawable/card_bg"
                    android:orientation="vertical"
                    android:padding="14dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Информация"
                        android:textColor="#3390EC"
                        android:textSize="13sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:text="Адрес"
                        android:textColor="#888888"
                        android:textSize="11sp" />

                    <TextView
                        android:id="@+id/tv_address"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="-"
                        android:textColor="#E0E0E0"
                        android:textSize="15sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp"
                        android:text="Порт"
                        android:textColor="#888888"
                        android:textSize="11sp" />

                    <TextView
                        android:id="@+id/tv_port"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="-"
                        android:textColor="#E0E0E0"
                        android:textSize="15sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp"
                        android:text="Ссылка для Telegram"
                        android:textColor="#888888"
                        android:textSize="11sp" />

                    <TextView
                        android:id="@+id/tv_tg_link"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="-"
                        android:textColor="#3390EC"
                        android:textSize="13sp"
                        android:ellipsize="end"
                        android:maxLines="2"
                        android:clickable="true"
                        android:foreground="?android:attr/selectableItemBackground" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:orientation="horizontal">

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Пинг"
                                android:textColor="#888888"
                                android:textSize="11sp" />
                            <TextView
                                android:id="@+id/tv_ping"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="-"
                                android:textColor="#E0E0E0"
                                android:textSize="15sp"
                                android:textStyle="bold" />
                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Трафик"
                                android:textColor="#888888"
                                android:textSize="11sp" />
                            <TextView
                                android:id="@+id/tv_traffic"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="-"
                                android:textColor="#E0E0E0"
                                android:textSize="14sp"
                                android:textStyle="bold" />
                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Аптайм"
                                android:textColor="#888888"
                                android:textSize="11sp" />
                            <TextView
                                android:id="@+id/tv_uptime"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="00:00:00"
                                android:textColor="#E0E0E0"
                                android:textSize="14sp"
                                android:textStyle="bold" />
                        </LinearLayout>
                    </LinearLayout>

                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:background="@drawable/card_bg"
                    android:orientation="vertical"
                    android:padding="14dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Режим работы"
                        android:textColor="#3390EC"
                        android:textSize="13sp"
                        android:textStyle="bold" />

                    <RadioGroup
                        android:id="@+id/rg_mode"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp">

                        <RadioButton
                            android:id="@+id/rb_original"
                            android:layout_width="wrap_content"
                            android:layout_height="36dp"
                            android:buttonTint="#3390EC"
                            android:checked="true"
                            android:text="Оригинал"
                            android:textColor="#E0E0E0"
                            android:textSize="14sp" />

                        <RadioButton
                            android:id="@+id/rb_python"
                            android:layout_width="wrap_content"
                            android:layout_height="36dp"
                            android:buttonTint="#3390EC"
                            android:text="Python-обходник"
                            android:textColor="#E0E0E0"
                            android:textSize="14sp" />

                        <RadioButton
                            android:id="@+id/rb_vless"
                            android:layout_width="wrap_content"
                            android:layout_height="36dp"
                            android:buttonTint="#3390EC"
                            android:text="VLESS"
                            android:textColor="#E0E0E0"
                            android:textSize="14sp" />
                    </RadioGroup>

                    <LinearLayout
                        android:id="@+id/ll_vless"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:orientation="vertical"
                        android:visibility="gone">

                        <EditText
                            android:id="@+id/et_vless"
                            android:layout_width="match_parent"
                            android:layout_height="40dp"
                            android:background="@drawable/edit_bg"
                            android:hint="vless://UUID@host:port?..."
                            android:inputType="textUri"
                            android:paddingStart="10dp"
                            android:paddingEnd="10dp"
                            android:singleLine="true"
                            android:textColor="#E0E0E0"
                            android:textColorHint="#555555"
                            android:textSize="12sp" />
                    </LinearLayout>
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:background="@drawable/card_bg"
                    android:orientation="vertical"
                    android:padding="14dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Настройки"
                        android:textColor="#3390EC"
                        android:textSize="13sp"
                        android:textStyle="bold" />

                    <CheckBox
                        android:id="@+id/cb_dynamic_port"
                        android:layout_width="wrap_content"
                        android:layout_height="36dp"
                        android:buttonTint="#3390EC"
                        android:text="Динамический порт"
                        android:textColor="#E0E0E0"
                        android:textSize="14sp" />

                    <CheckBox
                        android:id="@+id/cb_autostart"
                        android:layout_width="wrap_content"
                        android:layout_height="36dp"
                        android:buttonTint="#3390EC"
                        android:text="Автозапуск при открытии"
                        android:textColor="#E0E0E0"
                        android:textSize="14sp" />

                    <CheckBox
                        android:id="@+id/cb_smart_sleep"
                        android:layout_width="wrap_content"
                        android:layout_height="36dp"
                        android:buttonTint="#3390EC"
                        android:checked="true"
                        android:text="Умный сон (экономия батареи)"
                        android:textColor="#E0E0E0"
                        android:textSize="14sp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:text="Порт прокси (1-65535)"
                        android:textColor="#888888"
                        android:textSize="11sp" />

                    <EditText
                        android:id="@+id/et_custom_port"
                        android:layout_width="match_parent"
                        android:layout_height="40dp"
                        android:layout_marginTop="4dp"
                        android:background="@drawable/edit_bg"
                        android:hint="1080"
                        android:inputType="number"
                        android:paddingStart="10dp"
                        android:paddingEnd="10dp"
                        android:singleLine="true"
                        android:textColor="#E0E0E0"
                        android:textColorHint="#555555"
                        android:textSize="13sp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:text="IP локального прокси"
                        android:textColor="#888888"
                        android:textSize="11sp" />

                    <EditText
                        android:id="@+id/et_custom_ip"
                        android:layout_width="match_parent"
                        android:layout_height="40dp"
                        android:layout_marginTop="4dp"
                        android:background="@drawable/edit_bg"
                        android:hint="127.0.0.1"
                        android:inputType="textUri"
                        android:paddingStart="10dp"
                        android:paddingEnd="10dp"
                        android:singleLine="true"
                        android:textColor="#E0E0E0"
                        android:textColorHint="#555555"
                        android:textSize="13sp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:text="IP Telegram DC (для пинга)"
                        android:textColor="#888888"
                        android:textSize="11sp" />

                    <EditText
                        android:id="@+id/et_tg_ip"
                        android:layout_width="match_parent"
                        android:layout_height="40dp"
                        android:layout_marginTop="4dp"
                        android:background="@drawable/edit_bg"
                        android:hint="149.154.167.220"
                        android:inputType="textUri"
                        android:paddingStart="10dp"
                        android:paddingEnd="10dp"
                        android:singleLine="true"
                        android:textColor="#E0E0E0"
                        android:textColorHint="#555555"
                        android:textSize="13sp" />

                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:background="@drawable/card_bg"
                    android:orientation="vertical"
                    android:padding="14dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="О разработчике"
                        android:textColor="#3390EC"
                        android:textSize="13sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/tv_tg_channel"
                        android:layout_width="match_parent"
                        android:layout_height="36dp"
                        android:layout_marginTop="6dp"
                        android:gravity="center_vertical"
                        android:text="✈️ Telegram: @TgUnlock2026"
                        android:textColor="#E0E0E0"
                        android:textSize="13sp"
                        android:clickable="true"
                        android:foreground="?android:attr/selectableItemBackground" />

                    <TextView
                        android:id="@+id/tv_github"
                        android:layout_width="match_parent"
                        android:layout_height="36dp"
                        android:gravity="center_vertical"
                        android:text="⭐ GitHub: Genuys"
                        android:textColor="#E0E0E0"
                        android:textSize="13sp"
                        android:clickable="true"
                        android:foreground="?android:attr/selectableItemBackground" />

                </LinearLayout>

                <View
                    android:layout_width="1dp"
                    android:layout_height="16dp" />

            </LinearLayout>

            <!-- ======== TAB: WARP ======== -->
            <LinearLayout
                android:id="@+id/content_warp"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp"
                android:visibility="gone">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/card_bg"
                    android:orientation="vertical"
                    android:padding="16dp"
                    android:gravity="center">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="🛡️ Amnezia VPN"
                        android:textColor="#3390EC"
                        android:textSize="20sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:text="Идеальный и надежный VPN-туннель для быстрого обхода блокировок. Установите клиент, если его нет."
                        android:textColor="#888888"
                        android:textSize="12sp"
                        android:gravity="center" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="16dp"
                        android:orientation="horizontal"
                        android:weightSum="2">

                        <Button
                            android:id="@+id/btn_amnezia_playstore"
                            android:layout_width="0dp"
                            android:layout_height="48dp"
                            android:layout_weight="1"
                            android:layout_marginEnd="6dp"
                            android:background="@drawable/btn_start_bg"
                            android:text="📥 Скачать App"
                            android:textAllCaps="false"
                            android:textColor="#FFFFFF"
                            android:textSize="12sp" />

                        <Button
                            android:id="@+id/btn_amnezia_site"
                            android:layout_width="0dp"
                            android:layout_height="48dp"
                            android:layout_weight="1"
                            android:layout_marginStart="6dp"
                            android:background="@drawable/btn_start_bg"
                            android:text="🌐 Сайт-Инструкция"
                            android:textAllCaps="false"
                            android:textColor="#FFFFFF"
                            android:textSize="12sp" />
                    </LinearLayout>

                    <Button
                        android:id="@+id/btn_warp_instruction"
                        android:layout_width="match_parent"
                        android:layout_height="54dp"
                        android:layout_marginTop="20dp"
                        android:background="@drawable/btn_start_bg"
                        android:text="📖 Читать Инструкцию"
                        android:textAllCaps="false"
                        android:textColor="#FFFFFF"
                        android:textSize="14sp"
                        android:textStyle="bold" />
                </LinearLayout>
            </LinearLayout>
            <!-- ======== TAB: PROXY LIST ======== -->
            <LinearLayout
                android:id="@+id/content_proxy_list"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp"
                android:visibility="gone">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/card_bg"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="📋 Высокоскоростные сервера"
                        android:textColor="#3390EC"
                        android:textSize="16sp"
                        android:textStyle="bold" />

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="4dp" />

                    <Button
                        android:id="@+id/btn_proxy_refresh"
                        android:layout_width="match_parent"
                        android:layout_height="44dp"
                        android:layout_marginTop="10dp"
                        android:background="@drawable/btn_start_bg"
                        android:text="🔄 Обновить прокси"
                        android:textAllCaps="false"
                        android:textColor="#FFFFFF"
                        android:textSize="14sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/tv_proxy_list_status"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center"
                        android:layout_marginTop="8dp"
                        android:text="⏳ Загрузка..."
                        android:textColor="#FFAB00"
                        android:textSize="13sp" />

                </LinearLayout>

                <LinearLayout
                    android:id="@+id/ll_proxy_items"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:background="@drawable/card_bg"
                    android:orientation="vertical"
                    android:padding="12dp" />

            </LinearLayout>

            <!-- ======== TAB: DNS ======== -->
            <LinearLayout
                android:id="@+id/content_dns"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp"
                android:visibility="gone">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/card_bg"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="🌐 DNS unlock ИИ и игр"
                        android:textColor="#3390EC"
                        android:textSize="16sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/tv_dns_info"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="10dp"
                        android:text="GeoHide DNS — специальный DNS-сервер который разблокирует:\n\n🤖 ChatGPT, Claude, Gemini и другие ИИ\n🎮 Игровые сервисы, Discord\n📱 Социальные сети\n🌍 Заблокированные сайты\n\nДля активации установите Private DNS в настройках Android.\n\nАдрес: dns.geohide.ru"
                        android:textColor="#B0B0B0"
                        android:textSize="13sp"
                        android:lineSpacingExtra="3dp" />

                    <Button
                        android:id="@+id/btn_dns_activate"
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:layout_marginTop="16dp"
                        android:background="@drawable/btn_start_bg"
                        android:text="⚙️ Открыть настройки DNS"
                        android:textAllCaps="false"
                        android:textColor="#FFFFFF"
                        android:textSize="15sp"
                        android:textStyle="bold" />

                    <Button
                        android:id="@+id/btn_dns_copy"
                        android:layout_width="match_parent"
                        android:layout_height="44dp"
                        android:layout_marginTop="8dp"
                        android:background="@drawable/btn_stop_bg"
                        android:text="📋 Скопировать dns.geohide.ru"
                        android:textAllCaps="false"
                        android:textColor="#FFFFFF"
                        android:textSize="14sp" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
